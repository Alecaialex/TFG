<section class="hero">
    <HeroDecor/>
    <div class="wrap">
        <div class="hero-text">
            <div class="eyebrow">By an artist for every artist</div>
            <h1>
                Your <em>commissions</em>,
                your orders, <br />
                all in one place.
            </h1>
            
            <div class="subtitle">
                A single link to share. A board that fills itself. A queue you wished you had before.
            </div>

        </div>
        <div class="ctas">
            <a href="/auth" class="cta primary">
                <div class="role">I'm an artist</div>
                <div class="label">Register <span class="arrow">→</span></div>
            </a>
            <button class="cta">
                <div class="role">I want to commission</div>
                <div class="label">Find an artist <span class="arrow">→</span></div>
            </button>
        </div>
        <div class="hero-meta">
            <span><b>1,240</b> · artists onboard</span>
            <span>v0.1 · public beta</span>
        </div>
    </div>
</section>

