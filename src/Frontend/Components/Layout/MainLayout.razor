@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3">KommissMe</MudText>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavLink Href="/" Match="NavLinkMatch.All">Home</MudNavLink>
        <MudNavLink Href="/dashboard" Match="NavLinkMatch.Prefix">Dashboard</MudNavLink>
    </MudDrawer>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>
@code {
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    MudTheme _theme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Primary = Colors.Purple.Default,
            PrimaryDarken = Colors.Purple.Darken2,
            PrimaryLighten = Colors.Purple.Lighten2,
        },
        PaletteDark = new PaletteDark
        {
            Primary = Colors.Purple.Default,
            PrimaryDarken = Colors.Purple.Darken2,
            PrimaryLighten = Colors.Purple.Lighten2,
        }
    };
}